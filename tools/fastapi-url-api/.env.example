# Copy this file to .env and fill in your real key.
LLM_MODEL=gpt-5.4
LLM_PROVIDER=openai-custom
LLM_BASE_URL=https://api2.100zy.cn/v1
LLM_API_KEY=your_api_key_here

# MySQL config
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=crawlee_data

# OSS upload config
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=your_bucket_name
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
# Optional public access URL. If empty, backend auto builds one from bucket+endpoint.
OSS_PUBLIC_BASE_URL=

# DashScope vision config
DASHSCOPE_BASE_URL=https://llm-8pbtfdcbylx7i51t.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=your_dashscope_api_key
